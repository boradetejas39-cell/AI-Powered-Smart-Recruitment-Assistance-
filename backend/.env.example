# ===================================
# Backend Environment Variables
# Copy this to .env on Render
# ===================================

# Database Configuration
MONGODB_URI=mongodb+srv://ai_smart_recruiter:recruiter123@recruiter.vsvy6cx.mongodb.net/ai-recruiter?appName=Recruiter

# JWT Configuration
JWT_SECRET=ai-recruiter-super-secret-jwt-key-CHANGE-IN-PRODUCTION
JWT_EXPIRE=7d

# Server Configuration
PORT=5001
NODE_ENV=production

# Frontend URL (for CORS) — update after Vercel deploy
FRONTEND_URL=https://ai-recruiter.vercel.app

# Additional CORS Origins (comma-separated, optional)
# CORS_ORIGINS=https://preview-abc123.vercel.app,https://custom-domain.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
