{
  "name": "ai-recruiter",
  "version": "1.0.0",
  "description": "AI-Powered Smart Recruitment Assistant - Full Stack",
  "private": true,
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev",
    "client": "cd client && npm start",
    "backend": "cd backend && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd backend && npm install && cd ../client && npm install",
    "dev-full": "concurrently \"npm run backend\" \"npm run client\""
  },
  "keywords": [
    "ai",
    "recruitment",
    "hr",
    "resume",
    "matching",
    "mern"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
